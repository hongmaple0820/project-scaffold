{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Agent",
      "Skill",
      "Bash(make dev: *)",
      "Bash(make build: *)",
      "Bash(make test: *)",
      "Bash(make lint: *)",
      "Bash(make fmt: *)",
      "Bash(make gate: *)",
      "Bash(make plan: NAME=*)",
      "Bash(make checkpoint: *)",
      "Bash(make resume: *)",
      "Bash(make validate: *)",
      "Bash(make preflight: *)",
      "Bash(make graphify: *)",
      "Bash(go test ./...: *)",
      "Bash(go build -o bin/*: *)",
      "Bash(go run *: *)",
      "Bash(golangci-lint run: *)",
      "Bash(go vet ./...: *)",
      "Bash(go fmt ./...: *)",
      "Bash(go mod tidy: *)",
      "Bash(go mod download: *)",
      "Bash(git diff: *)",
      "Bash(git status: *)",
      "Bash(git log: *)",
      "Bash(git add: *)",
      "Bash(git commit: *)",
      "Bash(git push: *)",
      "Bash(git pull: *)",
      "Bash(git fetch: *)",
      "Bash(git branch: *)",
      "Bash(git checkout: *)",
      "Bash(git merge: *)",
      "Bash(git rebase: *)",
      "Bash(gh pr create: *)",
      "Bash(gh pr view: *)",
      "Bash(gh pr merge: *)",
      "Bash(gosec ./...: *)",
      "Bash(graphify: *)",
      "Bash(pip install: *)",
      "Bash(npm install: *)",
      "Bash(jq: *)",
      "Bash(scripts/*: *)",
      "Bash(bash scripts/*: *)",
      "Write(.claude/**)",
      "Write(.agent/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(templates/**)",
      "Write(README.md)",
      "Write(Makefile)",
      "Write(.gitignore)",
      "Edit(.claude/**)",
      "Edit(.agent/**)",
      "Edit(docs/**)",
      "Edit(scripts/**)",
      "Edit(templates/**)",
      "Edit(README.md)",
      "MultiEdit(docs/**)",
      "MultiEdit(scripts/**)",
      "Bash(scale:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /: *)",
      "Bash(curl | bash: *)",
      "Bash(curl | sh: *)",
      "Bash(wget | bash: *)",
      "Bash(DROP TABLE *: *)",
      "Bash(DROP DATABASE *: *)",
      "Bash(TRUNCATE TABLE *: *)",
      "Bash(DELETE FROM * WHERE: *)",
      "Bash(ALTER TABLE * DROP: *)",
      "Write(.env*)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(*.p12)",
      "Write(*.crt)",
      "Write(*private*)",
      "Write(*secret*)",
      "Write(*credential*)",
      "Write(*token*)",
      "Write(*password*)",
      "Edit(.env*)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(*secret*)",
      "Edit(*credential*)",
      "Edit(*token*)",
      "Edit(*password*)",
      "Edit(*private*)",
      "MultiEdit(.env*)"
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-filesystem",
        "."
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "command": "echo '[SCAFFOLD] CLAUDE.md 已优化 | 门控: make gate | 图谱: graphify .'",
        "description": "极简启动提醒",
        "timeout": 3000
      },
      {
        "matcher": "",
        "command": "scale context inject --session-id $CLAUDE_SESSION_ID"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write *.go|Edit *.go",
        "command": "bash scripts/hooks/check-explore.sh",
        "timeout": 3000,
        "description": "写.go前检查探索产物（工作流前置门控）"
      },
      {
        "matcher": "Write|Edit",
        "command": "bash scripts/hooks/check-dangerous-file.sh",
        "timeout": 3000,
        "description": "拦截危险文件修改"
      },
      {
        "matcher": "Write *.go",
        "command": "bash scripts/hooks/check-tdd.sh",
        "timeout": 3000,
        "description": "TDD合规提醒（首次提醒）"
      },
      {
        "matcher": "Bash",
        "command": "scale gate pre-tool Bash --args-json $TOOL_INPUT_JSON --session-id $CLAUDE_SESSION_ID"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit *.go",
        "command": "gofmt -w \"${CLAUDE_FILE_PATH}\" 2>/dev/null || true",
        "timeout": 3000,
        "description": "Go自动格式化"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": "scale gate post-tool Edit --args-json $TOOL_INPUT_JSON --output-json $TOOL_OUTPUT_JSON --session-id $CLAUDE_SESSION_ID"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "command": "DIRTY=$(git diff --name-only -- '*.go' 2>/dev/null | head -5); if [ -n \"$DIRTY\" ]; then echo '[STOP] 未提交的 .go 改动:'; echo \"$DIRTY\"; echo '考虑: git add + commit'; fi",
        "timeout": 5000,
        "description": "检查未提交改动"
      },
      {
        "matcher": "",
        "command": "scale gate before-stop --session-id $CLAUDE_SESSION_ID"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "command": "scale session end --session-id $CLAUDE_SESSION_ID"
      }
    ]
  }
}