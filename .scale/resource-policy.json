{
  "version": 1,
  "maxGitFileSizeBytes": 5242880,
  "ignoredDirectories": [
    ".git",
    "node_modules",
    "dist",
    "build",
    "vendor",
    ".next",
    ".turbo"
  ],
  "retainedRuntimeDirectories": [
    ".scale/tmp",
    ".scale/evidence",
    ".scale/reports",
    ".scale/resource-reports",
    "tmp",
    "temp",
    "test-results",
    "playwright-report",
    "coverage"
  ],
  "owners": {
    "docs": "engineering",
    "docs/standards": "engineering",
    "docs/workflow": "engineering",
    "docs/decisions": "architecture",
    "docs/modules": "module-owner",
    ".scale": "engineering"
  },
  "modules": {
    "example": {
      "path": "src/example",
      "owner": "team-or-owner"
    }
  }
}
