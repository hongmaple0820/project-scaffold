{
  "version": 1,
  "defaultProfile": "default",
  "profiles": {
    "default": {
      "commands": {},
      "services": []
    }
  },
  "services": [],
  "exclude": [
    "node_modules",
    "dist",
    "tmp",
    "vendor"
