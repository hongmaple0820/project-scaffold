{
  "version": "1.1",
  "stack": "auto",
  "coverage_threshold": 80,
  "profiles": {
    "scaffold": {
      "description": "Validate the reusable scaffold itself.",
      "checks": ["lint"]
    },
    "default": {
      "description": "Validate required product services for a generated project.",
      "services": [],
      "checks": ["lint", "test", "build"]
    },
    "all": {
      "description": "Validate every configured service.",
      "services": "*",
      "checks": ["lint", "test", "build", "security"]
    }
  },
  "services": {},
  "stacks": {
    "go": {
      "detect": ["go.mod"],
      "implementation_glob": "*.go",
      "test_suffix": "_test.go",
      "exclude_dirs": ["vendor", ".git", ".agent"],
      "commands": {
        "build": "go build ./...",
        "lint": "golangci-lint run --out-format=json > .agent/logs/lint.json",
        "test": "go test ./... -race -json > .agent/logs/test.json",
        "coverage": "go test -coverprofile=.agent/logs/coverage.out ./...",
        "security": "gosec -fmt json -out .agent/logs/gosec.json ./... >/dev/null"
      },
      "required_tools": {
        "build": ["go"],
        "lint": ["golangci-lint"],
        "test": ["go"],
        "coverage": ["go"],
        "security": ["gosec"]
      }
    },
    "node": {
      "detect": ["package.json"],
      "commands": {
        "build": "npm run build --if-present",
        "lint": "npm run lint",
        "test": "npm test",
        "coverage": "npm run coverage",
        "security": "npm audit --audit-level=high"
      },
      "required_tools": {
        "build": ["npm"],
        "lint": ["npm"],
        "test": ["npm"],
        "coverage": ["npm"],
        "security": ["npm"]
      }
    },
    "python": {
      "detect": ["pyproject.toml", "requirements.txt", "setup.py"],
      "commands": {
        "build": "python -m compileall .",
        "lint": "ruff check .",
        "test": "pytest",
        "coverage": "pytest --cov=. --cov-fail-under=80",
        "security": "bandit -r ."
      },
      "required_tools": {
        "build": ["python"],
        "lint": ["ruff"],
        "test": ["pytest"],
        "coverage": ["pytest"],
        "security": ["bandit"]
      }
    }
  }
}
